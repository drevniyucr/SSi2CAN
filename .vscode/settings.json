{
    // Заголовки этого проекта — чистый C (иначе IntelliSense парсит .h как C++)
    "files.associations": {
        "*.h": "c",
        "*.c": "c",
        "*.sv": "systemverilog",
        "*.svh": "systemverilog",
        "*.v": "verilog"
    },

    // Движок C/C++
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.default.cStandard": "c99",
    "C_Cpp.default.intelliSenseMode": "gcc-arm",

    // Показывать ошибки/подсказки только по этому проекту, не по всей библиотеке
    "C_Cpp.errorSquiggles": "enabled",

    // Семантическая подсветка (цвет по разобранным символам)
    "editor.semanticHighlighting.enabled": true,

    // Часть комментариев в исходниках — в CP1251; автоопределение кодировки
    // не даёт кракозябр (файлы в UTF-8 останутся UTF-8)
    "files.autoGuessEncoding": true
}
